{
  "name": "test-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:client": "pnpm --filter ./apps/client dev",
    "dev:server": "pnpm --filter ./apps/server dev",
    "dev:all": "pnpm -r dev",
    "build": "pnpm -r build",
    "build:client": "pnpm --filter ./apps/client build",
    "build:server": "pnpm --filter ./apps/server build",
    "lint": "pnpm -r lint",
    "preview": "pnpm --filter ./apps/client preview",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rimraf node_modules"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msw"]
  }
}
